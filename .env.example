TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_FROM_NUMBER=

# The BDM's own phone number, in E.164 format (e.g. +14155552671). Twilio
# calls this number first; once the BDM answers, they're bridged to the
# prospect so they can talk live.
BDM_PHONE_NUMBER=

# Base URL of the running twiml_server.py, reachable by Twilio over HTTPS
# (e.g. an ngrok URL like https://xxxx.ngrok.io). Do NOT include /connect —
# that path is appended automatically.
TWILIO_TWIML_URL=

# Optional: force dry-run mode even when the values above are filled in
# (true/false). Leave blank for normal behavior.
TWILIO_DRY_RUN=
